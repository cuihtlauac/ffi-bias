# Copy this file to `.env` (which is gitignored) and fill in the keys you need.
# api_client._load_dotenv() loads `.env` automatically on import, so the pipeline
# scripts pick these up with no extra ceremony. Existing environment variables win
# over this file, so an inline `KEY=val python ...` still overrides for one run.
#
#   cp .env.example .env && chmod 600 .env   # then edit .env
#
# Only set the keys for the providers you actually target (vendor is inferred from
# the model id in config.yaml). NEVER commit the real .env.

# Anthropic (claude-* models, and the judge when judge_model is claude-*)
ANTHROPIC_API_KEY=

# Google Gemini (gemini-* models)
GEMINI_API_KEY=

# OpenAI-compatible open-source hosts (model id prefixed cerebras:/together:/hf:)
CEREBRAS_API_KEY=
TOGETHER_API_KEY=
HF_TOKEN=

# Optional knobs (not secrets) — uncomment to set a default for every run:
# API_MIN_INTERVAL_S=8     # min seconds between API requests (free-tier pacing)
